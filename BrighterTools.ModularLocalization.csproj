<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PackageId>BrighterTools.ModularLocalization</PackageId>
    <Title>BrighterTools.ModularLocalization</Title>
    <RootNamespace>BrighterTools.ModularLocalization</RootNamespace>
    <Description>Modular localization runtime abstractions, caching, pluralization, and culture fallback for C# applications.</Description>
    <PackageTags>localization;i18n;translations;abstractions</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Caching.Memory" Version="10.0.9" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" Version="10.0.9" />
  </ItemGroup>

  <ItemGroup>
    <Compile Remove="EntityFrameworkCore\**\*.cs" />
    <Compile Remove="tests\**\*.cs" />
    <Compile Remove="artifacts\**\*.cs" />
    <Compile Remove="obj\**\*.cs" />
    <Compile Remove="bin\**\*.cs" />
    <None Remove="EntityFrameworkCore\**" />
    <None Remove="tests\**" />
    <None Remove="artifacts\**" />
    <None Remove="obj\**" />
    <None Remove="bin\**" />
    <Content Remove="EntityFrameworkCore\**" />
    <Content Remove="tests\**" />
    <Content Remove="artifacts\**" />
    <Content Remove="obj\**" />
    <Content Remove="bin\**" />
    <EmbeddedResource Remove="EntityFrameworkCore\**" />
    <EmbeddedResource Remove="tests\**" />
    <EmbeddedResource Remove="artifacts\**" />
    <EmbeddedResource Remove="obj\**" />
    <EmbeddedResource Remove="bin\**" />
  </ItemGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>BrighterTools.ModularLocalization.Tests</_Parameter1>
    </AssemblyAttribute>
    <AssemblyAttribute Include="System.Runtime.CompilerServices.InternalsVisibleTo">
      <_Parameter1>BrighterTools.ModularLocalization.EntityFrameworkCore</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>
</Project>
